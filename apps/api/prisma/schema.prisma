generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CreatorType {
  KOL
  CLIPPER
}

enum Platform {
  TIKTOK
  YOUTUBE
  INSTAGRAM
}

enum RateModel {
  FLAT
  PER_VIEW
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum UserRole {
  OWNER
  MEMBER
}

model Agency {
  id        String     @id @default(uuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  users     User[]
  creators  Creator[]
  campaigns Campaign[]
}

model User {
  id           String   @id @default(uuid())
  agencyId     String
  agency       Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  email        String   @unique
  passwordHash String
  role         UserRole @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([agencyId])
}

model Creator {
  id                 String         @id @default(uuid())
  agencyId           String
  agency             Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name               String
  type               CreatorType
  platform           Platform
  externalHandle     String
  followers          Int?
  avgEngagementRate  Float?
  niche              String[]       @default([])
  channelTitle       String?
  channelDescription String?
  subscriberCount    Int?
  channelViewCount   BigInt?
  channelPublishedAt DateTime?
  lastProfileSyncAt  DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  submissions        Submission[]
  scores             CreatorScore[]

  @@index([agencyId])
}

model Campaign {
  id           String       @id @default(uuid())
  agencyId     String
  agency       Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name         String
  brief        String?
  budget       Float
  rateModel    RateModel
  flatRate     Float?
  ratePerView  Float?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  submissions  Submission[]

  @@index([agencyId])
}

model Submission {
  id                String                     @id @default(uuid())
  campaignId        String
  campaign          Campaign                   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId         String
  creator           Creator                    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  contentUrl        String
  externalContentId String
  views             Int                        @default(0)
  likes             Int                        @default(0)
  comments          Int                        @default(0)
  title             String?
  description       String?
  publishedAt       DateTime?
  durationSeconds   Int?
  tags              String[]                   @default([])
  status            SubmissionStatus           @default(PENDING)
  lastSyncedAt      DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  payout            Payout?
  metricSnapshots   SubmissionMetricSnapshot[]

  @@index([campaignId])
  @@index([creatorId])
  @@index([status])
}

model SubmissionMetricSnapshot {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  views        Int
  likes        Int
  comments     Int
  capturedAt   DateTime   @default(now())

  @@index([submissionId, capturedAt])
}

model Payout {
  id           String       @id @default(uuid())
  submissionId String       @unique
  submission   Submission   @relation(fields: [submissionId], references: [id])
  amount       Float
  status       PayoutStatus @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

/// Phase 3 (vetting): computed creator score, recalculated as scoring logic matures.
model CreatorScore {
  id         String   @id @default(uuid())
  creatorId  String
  creator    Creator  @relation(fields: [creatorId], references: [id])
  score      Float
  breakdown  Json
  computedAt DateTime @default(now())

  @@index([creatorId])
}
