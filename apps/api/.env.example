# App
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://jengkol:jengkol@localhost:5432/jengkol?schema=public"

# Auth — generate a real secret for anything beyond local dev, e.g. `openssl rand -hex 32`
JWT_SECRET=dev-only-change-me-before-deploying-anywhere-real
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins for CORS. "*" allows any origin
# (not recommended beyond local dev).
CORS_ORIGIN=http://localhost:5173

# Observability
OTEL_SERVICE_NAME=jengkol-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# YouTube Data API v3 — https://developers.google.com/youtube/v3/docs/videos/list
# Create a key in Google Cloud Console with the YouTube Data API v3 enabled.
YOUTUBE_API_KEY=

# TikTok Display API v2 — https://developers.tiktok.com/doc/display-api-get-video-list/
# Requires an app registered at developers.tiktok.com and the video's own creator to
# complete OAuth login to your app (user access token, not an app-only key).
# There is no public "any video" stats endpoint — only videos owned by an authorized user.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LLM router (Phase 3 vetting agent) — comma-separated keys per provider, rotated
# round-robin within a provider; LLM_PROVIDER_ORDER is the fallback order once a
# provider's keys are all failing (rate-limited/invalid).
LLM_PROVIDER_ORDER=anthropic,openai
ANTHROPIC_API_KEYS=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENAI_API_KEYS=
OPENAI_MODEL=gpt-4o-mini

# Langfuse — LLM call tracing for the vetting agent (optional, skipped if unset)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# autoevals judge model — required only for `pnpm test:eval`, independent of which
# provider LLM_PROVIDER_ORDER picks for the vetting agent itself
OPENAI_API_KEY=
